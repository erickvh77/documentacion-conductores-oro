# ─── Base de datos ────────────────────────────────────────────────────────────
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_BD
DATABASE_URL="postgresql://postgres:password@localhost:5432/conductores_db"

# ─── Google Cloud — Service Account ──────────────────────────────────────────
# Email de la cuenta de servicio (ver Google Cloud Console → IAM → Service Accounts)
GOOGLE_SERVICE_ACCOUNT_EMAIL="mi-cuenta@mi-proyecto.iam.gserviceaccount.com"

# Clave privada de la cuenta de servicio.
# IMPORTANTE: copiar exactamente incluyendo -----BEGIN/END PRIVATE KEY-----
# En el .env local se puede pegar multilínea; en Docker usar \n como separador.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ─── Google Drive ─────────────────────────────────────────────────────────────
# ID de la carpeta raíz en Drive donde se guardarán los documentos.
# Ejemplo: https://drive.google.com/drive/folders/1ABC123XYZ → ID = 1ABC123XYZ
GOOGLE_DRIVE_ROOT_FOLDER_ID="1ABC123XYZxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── Google Sheets ────────────────────────────────────────────────────────────
# ID del spreadsheet donde se registrarán las filas.
# Ejemplo: https://docs.google.com/spreadsheets/d/1DEF456ABC → ID = 1DEF456ABC
GOOGLE_SHEETS_SPREADSHEET_ID="1DEF456ABCxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── Google Sheets VIAJES ─────────────────────────────────────────────────────
# Si la hoja VIAJES está en el mismo spreadsheet que Registros, usar el mismo ID.
GOOGLE_SHEETS_VIAJES_SPREADSHEET_ID="1DEF456ABCxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── Aplicación ───────────────────────────────────────────────────────────────
NODE_ENV="production"
# URL pública sin slash final — usada en Next.js para links absolutos
APP_URL="https://tudominio.com"
